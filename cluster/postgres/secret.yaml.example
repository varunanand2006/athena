# Copy this to secret.yaml and fill in base64-encoded values before applying.
# secret.yaml is gitignored — never commit real credentials.
#
# To encode a value:
#   echo -n 'yourvalue' | base64
#
# Defaults shown below are for local dev only — change before first apply.
apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: athena
type: Opaque
data:
  POSTGRES_USER: YXRoZW5h          # athena
  POSTGRES_PASSWORD: Y2hhbmdlbWU=  # changeme  ← REPLACE THIS
  POSTGRES_DB: YXRoZW5h            # athena
