# Copy to secret.yaml and fill in your base64-encoded session cookie before applying.
# secret.yaml is gitignored — never commit real credentials.
#
# To get your LEETCODE_SESSION cookie:
#   1. Log in to leetcode.com in your browser
#   2. Open DevTools → Application → Cookies → https://leetcode.com
#   3. Copy the value of the LEETCODE_SESSION cookie
#
# To base64-encode it:
#   echo -n 'your-session-value-here' | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: leetcode-secret
  namespace: athena
type: Opaque
data:
  LEETCODE_SESSION: <base64-encoded-session-cookie>
