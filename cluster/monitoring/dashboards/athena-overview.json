{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "Athena Overview",
  "uid": "athena-overview",
  "tags": ["athena", "phase22"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP (FastAPI services)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by service / route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service, route) (rate(athena_http_request_seconds_count[5m]))",
          "legendFormat": "{{service}} {{route}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP latency p50 / p95 by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(athena_http_request_seconds_bucket[5m])))",
          "legendFormat": "p95 {{service}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le, service) (rate(athena_http_request_seconds_bucket[5m])))",
          "legendFormat": "p50 {{service}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "LLM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "LLM latency p95 by operation",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(athena_llm_request_seconds_bucket[5m])))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Token spend by model / kind",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model, kind) (rate(athena_llm_tokens_total[5m]) * 60)",
          "legendFormat": "{{model}} {{kind}} /min"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "LLM errors (1h)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service, operation) (increase(athena_llm_errors_total[1h]))",
          "legendFormat": "{{service}} {{operation}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Cumulative tokens by model",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (athena_llm_tokens_total)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Background jobs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Job duration p95 by job",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(athena_job_seconds_bucket[30m])))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Job failures & empty results (1h increase)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (increase(athena_job_failures_total[1h]))",
          "legendFormat": "fail {{job}}"
        },
        {
          "refId": "B",
          "expr": "sum by (job) (increase(athena_job_empty_result_total[1h]))",
          "legendFormat": "empty {{job}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "RAG",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "find_documents empty rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(athena_rag_empty_total[30m])) / clamp_min(sum(rate(athena_rag_lookups_total[30m])), 0.0001)",
          "legendFormat": "empty fraction"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "RAG lookups vs empty (rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(athena_rag_lookups_total[30m]))",
          "legendFormat": "lookups"
        },
        {
          "refId": "B",
          "expr": "sum(rate(athena_rag_empty_total[30m]))",
          "legendFormat": "empty"
        }
      ]
    }
  ]
}
